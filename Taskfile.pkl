amends "package://pkg.pkl-lang.org/github.com/mizchi/pkfire/pkfire@0.12.3#/Taskfile.pkl"

local tsSources: Listing<String> = new {
  "src/matchlook_pipeline.ts"
  "src/jxa.d.ts"
  "tsconfig.json"
}

local emit: Task = new {
  name = "emit"
  description = "tsc で型検査 + src/dist へ JS 出力"
  cmd = "PATH=\"$HOME/.bun/bin:$PATH\" bunx tsc -p tsconfig.json"
  inputs = tsSources
  outputs { "src/dist/matchlook_pipeline.js" }
}

local compile: Task = new {
  name = "compile"
  description = "JS を osacompile で .scpt 化"
  cmd = "osacompile -l JavaScript -o src/dist/matchlook_pipeline.scpt src/dist/matchlook_pipeline.js"
  inputs { "src/dist/matchlook_pipeline.js" }
  outputs { "src/dist/matchlook_pipeline.scpt" }
  deps { emit }
}

local build: Task = new {
  name = "build"
  description = "emit -> compile（.scpt 生成まで）"
  deps { compile }
}

local all: Task = new {
  name = "all"
  description = "Denoised フォルダ全体を処理（Capture One 起動中前提）"
  cmd = "SCOPE=all MATCHLOOK=$MATCHLOOK osascript -l JavaScript src/dist/matchlook_pipeline.js"
  deps { emit }
  cache = false
  params {
    new { name = "matchlook"; type = "bool"; default = "true"; description = "Match Look を適用するか" }
  }
}

local sel: Task = new {
  name = "sel"
  description = "Capture One で現在選択中の DNG のみ処理"
  cmd = "SCOPE=sel MATCHLOOK=$MATCHLOOK osascript -l JavaScript src/dist/matchlook_pipeline.js"
  deps { emit }
  cache = false
  params {
    new { name = "matchlook"; type = "bool"; default = "true"; description = "Match Look を適用するか" }
  }
}

local install: Task = new {
  name = "install"
  description = ".scpt を Capture One Scripts フォルダへ配置"
  cmd = "mkdir -p \"$HOME/Library/Scripts/Capture One Scripts\" && cp src/dist/matchlook_pipeline.scpt \"$HOME/Library/Scripts/Capture One Scripts/matchlook_pipeline.scpt\""
  deps { compile }
  cache = false
}

tasks { emit; compile; build; all; sel; install }
