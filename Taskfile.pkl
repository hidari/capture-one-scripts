amends "package://pkg.pkl-lang.org/github.com/mizchi/pkfire/pkfire@0.12.3#/Taskfile.pkl"

local tsSources: Listing<String> = new {
  "src/matchlook_pipeline.ts"
  "src/jxa.d.ts"
  "tsconfig.json"
}

// C1 Scripts メニューに表示されるラベル(= インストール先ファイル名)。
local menuName: String = "Apply Match Look from Reference"

local emit: Task = new {
  name = "emit"
  description = "tsc で型検査 + src/dist へ JS 出力"
  cmd = "PATH=\"$HOME/.bun/bin:$PATH\" bunx tsc -p tsconfig.json"
  inputs = tsSources
  outputs { "src/dist/matchlook_pipeline.js" }
}

local compile: Task = new {
  name = "compile"
  description = "JS を osacompile で .scpt 化"
  cmd = "osacompile -l JavaScript -o src/dist/matchlook_pipeline.scpt src/dist/matchlook_pipeline.js"
  inputs { "src/dist/matchlook_pipeline.js" }
  outputs { "src/dist/matchlook_pipeline.scpt" }
  deps { emit }
}

local build: Task = new {
  name = "build"
  description = "emit -> compile（.scpt 生成まで）"
  deps { compile }
}

local sel: Task = new {
  name = "sel"
  description = "Capture One で現在選択中の対象に Match Look を適用"
  cmd = "osascript -l JavaScript src/dist/matchlook_pipeline.js"
  deps { emit }
  cache = false
}

local install: Task = new {
  name = "install"
  description = ".scpt を Capture One Scripts フォルダへ配置"
  cmd = "mkdir -p \"$HOME/Library/Scripts/Capture One Scripts\" && rm -f \"$HOME/Library/Scripts/Capture One Scripts/matchlook_pipeline.scpt\" && cp src/dist/matchlook_pipeline.scpt \"$HOME/Library/Scripts/Capture One Scripts/\(menuName).scpt\""
  deps { compile }
  cache = false
}

local test: Task = new {
  name = "test"
  description = "pure ロジックのユニットテスト(node --test)"
  cmd = "node --test test/pure.test.mjs"
  deps { emit }
  cache = false
}

tasks { emit; compile; build; sel; install; test }
